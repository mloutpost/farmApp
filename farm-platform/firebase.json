{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/family-dashboard/handwriting", "destination": "/family-dashboard/handwriting.html" },
      { "source": "/family-dashboard/travel-planning", "destination": "/family-dashboard/travel-planning.html" },
      { "source": "/family-dashboard/connect-gmail", "destination": "/family-dashboard/connect-gmail.html" },
      { "source": "/family-dashboard/feed", "destination": "/family-dashboard/feed.html" },
      { "source": "/family-dashboard", "destination": "/family-dashboard.html" },
      { "source": "/beth", "destination": "/beth.html" },
      { "source": "/ops", "destination": "/ops.html" },
      { "source": "/tax", "destination": "/tax.html" },
      { "source": "/flow", "destination": "/flow.html" },
      { "source": "/settings", "destination": "/settings.html" },
      { "source": "/node", "destination": "/node.html" },
      { "source": "/timeline", "destination": "/timeline.html" },
      { "source": "/calendar", "destination": "/calendar.html" },
      { "source": "/tasks", "destination": "/tasks.html" },
      { "source": "/finances", "destination": "/finances.html" },
      { "source": "/reports", "destination": "/reports.html" }
    ]
  }
}
