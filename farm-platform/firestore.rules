rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // app_settings is read by the client for config (e.g. Google Maps API key).
    // Only admins should write; use the seed script or Firebase Console.
    match /app_settings/{document} {
      allow read: if true;
      allow write: if false;
    }
    // Add your other collection rules below
  }
}
