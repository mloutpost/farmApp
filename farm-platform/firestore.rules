rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // app_settings is read by the client for config (e.g. Google Maps API key).
    // Only admins should write; use the seed script or Firebase Console.
    match /app_settings/{document} {
      allow read: if true;
      allow write: if false;
    }
    // User farm data: each signed-in user (including anonymous) can read/write their own.
    match /users/{userId}/farm/data {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Liturgical-year daily entries (one document per YYYY-MM-DD).
    // Written by the in-app feed page and the import-liturgical-email script
    // (the script uses firebase-admin which bypasses these rules).
    match /users/{userId}/liturgicalYear/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Family-dashboard configuration (e.g. the chosen Gmail source for the
    // Liturgical Year wizard). Each user reads and writes their own.
    match /users/{userId}/familyDashboard/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Demo farm: anyone can read (for new users to try). Authenticated users can write (to save demo).
    match /demo/farm {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
